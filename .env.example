# Backend (Express API) environment
# Copy to .env.local and fill real secrets. Never commit real values.

NODE_ENV=development
PORT=3001
MAIN_DOMAIN=your-domain.com

# Auth & cookies
JWT_SECRET=
AUTH_COOKIE_NAME=itm_access
AUTH_CSRF_COOKIE=itm_csrf
AUTH_COOKIE_MAX_AGE_DAYS=7
AUTH_COOKIE_DOMAIN=

# Rate limits
API_RATE_WINDOW_MS=60000
API_RATE_MAX=300
AUTH_RATE_WINDOW_MS=60000
AUTH_RATE_MAX=200
DISABLE_API_RATE_LIMIT=false

# Supabase (service role for server-side DB access)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Optional fallback if code expects VITE_SUPABASE_URL (legacy)
VITE_SUPABASE_URL=

# Mailer. Configure one provider for OTP delivery.
# Recommended: Resend. RESEND_FROM_EMAIL must be a verified sender/domain.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
OTP_FROM_EMAIL=
NO_REPLY_FROM_EMAIL=
EMAIL_FROM_NAME=IndianTradeMart

GMAIL_EMAIL=
GMAIL_APP_PASSWORD=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
FRONTEND_URL=https://your-domain.com

# CORS
CORS_EXTRA_ORIGINS=
CORS_ALLOWED_HEADERS=

# Dev admin bootstrap (optional)
DEV_ADMIN_EMAIL=
DEV_ADMIN_PASSWORD=
