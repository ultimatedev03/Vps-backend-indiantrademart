# Backend (Express API) environment
# Copy to .env.local and fill real secrets. Never commit real values.

NODE_ENV=development
PORT=3001
MAIN_DOMAIN=your-domain.com

# Auth & cookies
JWT_SECRET=
AUTH_COOKIE_NAME=itm_access
AUTH_CSRF_COOKIE=itm_csrf
AUTH_COOKIE_MAX_AGE_DAYS=7
AUTH_COOKIE_DOMAIN=

# Rate limits
API_RATE_WINDOW_MS=60000
API_RATE_MAX=300
AUTH_RATE_WINDOW_MS=60000
AUTH_RATE_MAX=200
DISABLE_API_RATE_LIMIT=false

# MySQL (local Workbench default)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=indiantrademart
MYSQL_CONNECTION_LIMIT=10
MYSQL_STORAGE_DIR=./uploads
PUBLIC_STORAGE_URL=/uploads

# Mailer. Configure one provider for OTP delivery.
# Recommended: Resend. RESEND_FROM_EMAIL must be a verified sender/domain.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
OTP_FROM_EMAIL=
NO_REPLY_FROM_EMAIL=
EMAIL_FROM_NAME=IndianTradeMart

GMAIL_EMAIL=
GMAIL_APP_PASSWORD=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
FRONTEND_URL=https://your-domain.com

# Buffered visitor analytics, rollups, and bounded retention.
ANALYTICS_CRON_ENABLED=false
ANALYTICS_CRON_TIMEZONE=Asia/Kolkata
ANALYTICS_REFRESH_CRON=*/30 * * * *
ANALYTICS_RETENTION_CRON=20 3 * * *
ANALYTICS_RAW_RETENTION_DAYS=180
ANALYTICS_QUEUE_RETENTION_DAYS=30
ANALYTICS_AGGREGATE_RETENTION_DAYS=400
ANALYTICS_RETENTION_CHUNK_SIZE=5000

# Encrypted/private backup storage should use a separate, non-public bucket.
DB_BACKUP_DIR=./backups/mysql
DB_BACKUP_RETENTION_DAYS=30
DB_BACKUP_S3_ENDPOINT=
DB_BACKUP_S3_REGION=auto
DB_BACKUP_S3_BUCKET=
DB_BACKUP_S3_ACCESS_KEY_ID=
DB_BACKUP_S3_SECRET_ACCESS_KEY=
DB_BACKUP_S3_PREFIX=mysql

# CORS
CORS_EXTRA_ORIGINS=
CORS_ALLOWED_HEADERS=

# Dev admin bootstrap (optional)
DEV_ADMIN_EMAIL=
DEV_ADMIN_PASSWORD=

# Cloudflare R2 / S3-compatible static sitemap snapshots.
# Each run publishes versioned 50,000-URL gzip shards, then atomically switches sitemap-index.xml.
R2_ACCOUNT_ID=
R2_ENDPOINT=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_SITEMAP_PUBLIC_BASE_URL=https://sitemaps.your-domain.com
# Crawler-facing shard host. Keep this on the verified primary site.
SITEMAP_CRAWLER_BASE_URL=https://your-domain.com
R2_SITEMAP_PREFIX=sitemaps
SITEMAP_R2_URL_LIMIT=50000
SITEMAP_R2_QUERY_LIMIT=2000
SITEMAP_R2_GZIP_LEVEL=6
SITEMAP_R2_RETAIN_SNAPSHOTS=4
SITEMAP_CATEGORY_SCOPE=all
# Optional hard cap. Leave blank to publish every generated canonical URL.
SITEMAP_R2_MAX_URLS=
# Optional deterministic ID for testing; production defaults to a timestamp.
SITEMAP_R2_SNAPSHOT_ID=
