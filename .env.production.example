NODE_ENV=production
PORT=3100
MAIN_DOMAIN=your-domain.com

JWT_SECRET=replace-with-a-long-random-secret
AUTH_COOKIE_NAME=itm_access
AUTH_CSRF_COOKIE=itm_csrf
AUTH_COOKIE_MAX_AGE_DAYS=7
AUTH_COOKIE_DOMAIN=.your-domain.com

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
VITE_SUPABASE_URL=

# OTP/email delivery. Configure one provider before enabling production signup.
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Or use SMTP/Gmail fallback. For Gmail, use an app password without spaces.
GMAIL_EMAIL=
GMAIL_APP_PASSWORD=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

FRONTEND_URL=https://your-domain.com

API_RATE_WINDOW_MS=60000
API_RATE_MAX=60
AUTH_RATE_WINDOW_MS=60000
AUTH_RATE_MAX=60
DISABLE_API_RATE_LIMIT=false

CORS_EXTRA_ORIGINS=https://www.your-domain.com
CORS_ALLOWED_HEADERS=
