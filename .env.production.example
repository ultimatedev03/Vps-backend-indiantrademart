NODE_ENV=production
PORT=3100
MAIN_DOMAIN=indiantrademart.com

JWT_SECRET=replace-with-a-long-random-secret
AUTH_COOKIE_NAME=itm_access
AUTH_CSRF_COOKIE=itm_csrf
AUTH_COOKIE_MAX_AGE_DAYS=7
AUTH_COOKIE_DOMAIN=.indiantrademart.com

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=change-this-on-vps
MYSQL_DATABASE=indiantrademart
MYSQL_CONNECTION_LIMIT=20
MYSQL_STORAGE_DIR=/var/www/indiantrademart/uploads
PUBLIC_STORAGE_URL=/uploads

# OTP/email delivery. Configure one provider before enabling production signup.
# Recommended: Resend. RESEND_FROM_EMAIL must be a verified sender/domain.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
OTP_FROM_EMAIL=
NO_REPLY_FROM_EMAIL=
EMAIL_FROM_NAME=IndianTradeMart

# Or use SMTP/Gmail fallback. For Gmail, use an app password without spaces.
GMAIL_EMAIL=
GMAIL_APP_PASSWORD=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

FRONTEND_URL=https://indiantrademart.com

ANALYTICS_CRON_ENABLED=true
ANALYTICS_CRON_TIMEZONE=Asia/Kolkata
ANALYTICS_REFRESH_CRON=*/30 * * * *
ANALYTICS_RETENTION_CRON=20 3 * * *
ANALYTICS_RAW_RETENTION_DAYS=180
ANALYTICS_QUEUE_RETENTION_DAYS=30
ANALYTICS_AGGREGATE_RETENTION_DAYS=400
ANALYTICS_RETENTION_CHUNK_SIZE=5000

DB_BACKUP_DIR=/var/backups/indiantrademart/mysql
DB_BACKUP_RETENTION_DAYS=30
# Optional private offsite bucket. Never use the public sitemap bucket.
DB_BACKUP_S3_ENDPOINT=
DB_BACKUP_S3_REGION=auto
DB_BACKUP_S3_BUCKET=
DB_BACKUP_S3_ACCESS_KEY_ID=
DB_BACKUP_S3_SECRET_ACCESS_KEY=
DB_BACKUP_S3_PREFIX=mysql

API_RATE_WINDOW_MS=60000
API_RATE_MAX=1200
AUTH_RATE_WINDOW_MS=60000
AUTH_RATE_MAX=60
DISABLE_API_RATE_LIMIT=false

CORS_EXTRA_ORIGINS=https://www.indiantrademart.com,https://api.indiantrademart.com
CORS_ALLOWED_HEADERS=

# Cloudflare R2 static sitemap snapshots.
# Submit only https://indiantrademart.com/sitemap.xml in Google Search Console.
R2_ACCOUNT_ID=
R2_BUCKET=indiantrademart-sitemaps
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_SITEMAP_PUBLIC_BASE_URL=https://sitemaps.indiantrademart.com
SITEMAP_CRAWLER_BASE_URL=https://indiantrademart.com
R2_SITEMAP_PREFIX=sitemaps
SITEMAP_R2_URL_LIMIT=50000
SITEMAP_R2_QUERY_LIMIT=2000
SITEMAP_R2_GZIP_LEVEL=6
SITEMAP_R2_RETAIN_SNAPSHOTS=4
SITEMAP_CATEGORY_SCOPE=all
SITEMAP_R2_MAX_URLS=
SITEMAP_R2_SNAPSHOT_ID=
