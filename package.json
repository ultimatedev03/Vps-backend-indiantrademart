{
  "name": "indiantrademart-backend",
  "private": true,
  "type": "module",
  "description": "Backend (Express API) wrapper for local dev/start after FE/BE separation.",
  "scripts": {
    "dev": "node --watch server/server.js",
    "start": "node server/server.js",
    "db:setup": "node server/scripts/setupMysqlSchema.js",
    "seo:setup:page-meta": "node server/scripts/setupPageSeoOverrides.js",
    "db:build:geo-csv": "node server/scripts/buildCityPopulationGeoCsv.js",
    "db:import:geo-csv": "node server/scripts/importGeoPostalRawCsv.js",
    "db:sync:delhi-cities": "node server/scripts/syncDelhiCities.js",
    "db:sync:india-locations": "node server/scripts/syncIndiaLocations.js",
    "db:migrate:supabase": "node server/scripts/migrateSupabaseToMysql.js",
    "db:migrate:postgres": "node server/scripts/migratePostgresToMysql.js",
    "storage:migrate:supabase": "node server/scripts/migrateSupabaseStorageToLocal.js",
    "search:setup": "node server/scripts/setupOpenSearchCatalog.js",
    "search:reindex": "node server/scripts/reindexOpenSearchProducts.js",
    "analytics:behavioral": "node server/scripts/runBehavioralCommerceIntelligence.js",
    "analytics:kafka:consume": "node server/scripts/consumeBehavioralKafkaEvents.js",
    "db:backup": "node server/scripts/backupMysql.js",
    "seo:export:all-urls": "node -e \"console.log('SEO URL ZIP export is disabled. Versioned static R2 sitemap snapshots are the canonical pipeline.')\"",
    "seo:sitemap:r2:publish": "node server/scripts/publishR2Sitemaps.js",
    "categories:import-keywords": "node server/scripts/importCategoryKeywords.js",
    "plans:seed": "node server/scripts/seedVendorPlanCatalog.js",
    "plans:guide": "node server/scripts/generatePlanSalesGuide.js",
    "images:optimize": "node server/scripts/optimizeLocalImages.js",
    "admin:create": "node server/scripts/createAdmin.js",
    "admin:password": "node server/scripts/changeAdminPassword.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.614.0",
    "@clickhouse/client": "^1.23.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.1.5",
    "groq-sdk": "^0.6.0",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.0.0",
    "kafkajs": "^2.2.4",
    "mysql2": "^3.22.4",
    "node-cron": "^4.2.1",
    "nodemailer": "^9.0.1",
    "openai": "^4.77.4",
    "pg": "^8.21.0",
    "razorpay": "^2.9.6",
    "sharp": "0.35.3"
  }
}
